{
  "version": 2,
  "builds": [
    {
      "src": "backend/frontend/**",
      "use": "@vercel/static"
    },
    {
      "src": "backend/main.py",
      "use": "@vercel/python"
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/backend/main.py"
    },
    {
      "source": "/static/(.*)",
      "destination": "/backend/frontend/$1"
    },
    {
      "source": "/chat/(.*)",
      "destination": "/backend/frontend/index.html"
    },
    {
      "source": "/",
      "destination": "/backend/frontend/index.html"
    },
    {
      "source": "/(.*)",
      "destination": "/backend/main.py"
    }
  ]
}