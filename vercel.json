{
  "version": 2,
  "builds": [
    {
      "src": "backend/main.py",
      "use": "@vercel/python",
      "config": {
        "includeFiles": "backend/frontend/**"
      }
    }
  ],
  "functions": {
    "backend/main.py": {
      "maxDuration": 60
    }
  },
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/backend/main.py"
    }
  ]
}